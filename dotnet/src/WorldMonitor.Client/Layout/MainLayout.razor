@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.Public" Class="mr-2" />
        <MudText Typo="Typo.h6">World Monitor</MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption">.NET 10 · Blazor WebAssembly</MudText>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Public">Earthquakes</MudNavLink>
            <MudNavLink Href="/news" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Newspaper">World News</MudNavLink>
            <MudNavLink Href="/tech-news" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Memory">Tech &amp; AI News</MudNavLink>
            <MudNavLink Href="/intel" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TravelExplore">Global Intel</MudNavLink>
            <MudNavLink Href="/trending" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TrendingUp">Trending</MudNavLink>
            <MudNavLink Href="/hacker-news" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Forum">Hacker News</MudNavLink>
            <MudNavLink Href="/markets" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CurrencyBitcoin">Markets</MudNavLink>
            <MudNavLink Href="/trending-crypto" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalFireDepartment">Trending Crypto</MudNavLink>
            <MudNavLink Href="/fx" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CurrencyExchange">Exchange Rates</MudNavLink>
            <MudNavLink Href="/economy" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalance">Global Economy</MudNavLink>
            <MudNavLink Href="/energy" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Bolt">UK Energy Mix</MudNavLink>
            <MudNavLink Href="/sentiment" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Mood">Fear &amp; Greed</MudNavLink>
            <MudNavLink Href="/clock" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schedule">World Clock</MudNavLink>
            <MudNavLink Href="/natural" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalFireDepartment">Natural Events</MudNavLink>
            <MudNavLink Href="/disasters" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Warning">Global Disasters</MudNavLink>
            <MudNavLink Href="/volcano" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Volcano">Volcano Alerts</MudNavLink>
            <MudNavLink Href="/weather-alerts" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CrisisAlert">US Weather Alerts</MudNavLink>
            <MudNavLink Href="/weather" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Cloud">Global Weather</MudNavLink>
            <MudNavLink Href="/air-quality" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Air">Air Quality</MudNavLink>
            <MudNavLink Href="/displacement" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Groups">Displacement</MudNavLink>
            <MudNavLink Href="/security" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Security">Security Advisories</MudNavLink>
            <MudNavLink Href="/status" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">Service Status</MudNavLink>
            <MudNavLink Href="/space" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SatelliteAlt">Space Weather</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
