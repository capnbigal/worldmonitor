@page "/displacement"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Forced Displacement</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Refugees, asylum-seekers &amp; IDPs by country of origin (UNHCR, 2024)</MudText>

<MudButton OnClick="Load" Variant="Variant.Filled" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading" Class="mb-4">
    @(_loading ? "Loading…" : "Refresh")
</MudButton>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="my-2">
        Couldn't load data: @_error
        <div><MudText Typo="Typo.caption">Tip: launch the API host (<code>dotnet run --project dotnet/src/WorldMonitor.Api</code>), not the Client project.</MudText></div>
    </MudAlert>
}
else if (_items is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="_items" Dense="true" Hover="true" Striped="true" FixedHeader="true" Height="60vh">
        <HeaderContent>
            <MudTh>Country (of origin)</MudTh>
            <MudTh Style="text-align:right">Refugees</MudTh>
            <MudTh Style="text-align:right">Asylum Seekers</MudTh>
            <MudTh Style="text-align:right">IDPs</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Country">@context.Country</MudTd>
            <MudTd DataLabel="Refugees" Style="text-align:right">@context.Refugees.ToString("N0")</MudTd>
            <MudTd DataLabel="Asylum Seekers" Style="text-align:right">@context.AsylumSeekers.ToString("N0")</MudTd>
            <MudTd DataLabel="IDPs" Style="text-align:right">@context.Idps.ToString("N0")</MudTd>
        </RowTemplate>
    </MudTable>
    <MudText Typo="Typo.caption" Class="mt-2">@_items.Count countries</MudText>
}

@code {
    private IReadOnlyList<DisplacementByCountry>? _items;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<ListDisplacementResponse>("api/displacement/v1/by-country");
            _items = resp?.Items ?? [];
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
