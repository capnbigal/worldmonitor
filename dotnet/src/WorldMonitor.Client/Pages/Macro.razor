@page "/macro"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Macro Indicators</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Latest US macro &amp; financial series (rates, inflation, unemployment, VIX…) from the St. Louis Fed (FRED).</MudText>

<MudButton OnClick="Load" Variant="Variant.Filled" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading" Class="mb-4">
    @(_loading ? "Loading…" : "Refresh")
</MudButton>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="my-2">
        Couldn't load data: @_error
        <div><MudText Typo="Typo.caption">Tip: launch the API host (<code>dotnet run --project dotnet/src/WorldMonitor.Api</code>), not the Client project.</MudText></div>
    </MudAlert>
}
else if (_response is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!_response.Configured)
{
    <MudAlert Severity="Severity.Info" Class="my-2">
        <MudText Typo="Typo.subtitle2">This panel needs a free FRED API key.</MudText>
        <ol style="margin:0.5rem 0 0 1.2rem">
            <li>Register (free) at <MudLink Href="https://fred.stlouisfed.org/docs/api/api_key.html" Target="_blank">fred.stlouisfed.org</MudLink> to get an API key.</li>
            <li>Set it in <code>dotnet/src/WorldMonitor.Api/appsettings.json</code> under <code>ExternalApis:Fred</code> — or the environment variable <code>ExternalApis__Fred</code>.</li>
            <li>Restart the API host and refresh.</li>
        </ol>
        <MudText Typo="Typo.caption" Class="mt-1">The app works fully without this key — only this panel is gated.</MudText>
    </MudAlert>
}
else
{
    <MudTable Items="_response.Items" Dense="true" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Indicator</MudTh>
            <MudTh Style="text-align:right">Latest</MudTh>
            <MudTh Style="width:120px">Units</MudTh>
            <MudTh Style="width:140px">As of</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Indicator">@context.Name <MudText Typo="Typo.caption" Class="mud-text-secondary d-inline">(@context.SeriesId)</MudText></MudTd>
            <MudTd DataLabel="Latest" Style="text-align:right">@context.Value.ToString("0.###")</MudTd>
            <MudTd DataLabel="Units">@context.Units</MudTd>
            <MudTd DataLabel="As of">@context.Date</MudTd>
        </RowTemplate>
    </MudTable>
    <MudText Typo="Typo.caption" Class="mt-2">@_response.Items.Count indicators · FRED</MudText>
}

@code {
    private ListMacroResponse? _response;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            _response = await Http.GetFromJsonAsync<ListMacroResponse>("api/macro/v1/indicators") ?? new ListMacroResponse();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
