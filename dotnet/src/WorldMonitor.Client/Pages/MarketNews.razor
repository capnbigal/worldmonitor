@page "/market-news"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Market News</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Financial-market headlines (Finnhub)</MudText>

<MudButton OnClick="Load" Variant="Variant.Filled" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading" Class="mb-4">
    @(_loading ? "Loading…" : "Refresh")
</MudButton>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="my-2">
        Couldn't load data: @_error
        <div><MudText Typo="Typo.caption">Tip: launch the API host (<code>dotnet run --project dotnet/src/WorldMonitor.Api</code>), not the Client project.</MudText></div>
    </MudAlert>
}
else if (_response is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!_response.Configured)
{
    <MudAlert Severity="Severity.Info" Class="my-2">
        <MudText Typo="Typo.subtitle2">This panel needs a free Finnhub API key.</MudText>
        <ol style="margin:0.5rem 0 0 1.2rem">
            <li>Register (free) at <MudLink Href="https://finnhub.io/register" Target="_blank">finnhub.io</MudLink> to get an API key.</li>
            <li>Set it in <code>dotnet/src/WorldMonitor.Api/appsettings.json</code> under <code>ExternalApis:Finnhub</code> — or the environment variable <code>ExternalApis__Finnhub</code>.</li>
            <li>Restart the API host and refresh.</li>
        </ol>
        <MudText Typo="Typo.caption" Class="mt-1">The app works fully without this key — only this panel is gated.</MudText>
    </MudAlert>
}
else
{
    <MudList T="NewsItem" Dense="true">
        @foreach (var item in _response.Items)
        {
            <MudListItem T="NewsItem" Href="@item.Link" Target="_blank">
                <div class="d-flex align-center gap-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@item.Source</MudChip>
                    <MudText Typo="Typo.body1" Class="flex-grow-1">@item.Title</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@Ago(item.PublishedAt)</MudText>
                </div>
                @if (!string.IsNullOrWhiteSpace(item.Summary))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.Summary</MudText>
                }
            </MudListItem>
            <MudDivider />
        }
    </MudList>
    <MudText Typo="Typo.caption" Class="mt-2">@_response.Items.Count headlines · Finnhub</MudText>
}

@code {
    private WorldMonitor.Contracts.MarketNews.ListMarketNewsResponse? _response;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            _response = await Http.GetFromJsonAsync<WorldMonitor.Contracts.MarketNews.ListMarketNewsResponse>("api/markets/v1/news") ?? new WorldMonitor.Contracts.MarketNews.ListMarketNewsResponse();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string Ago(long epochMs)
    {
        if (epochMs <= 0) return "";
        var span = DateTimeOffset.UtcNow - DateTimeOffset.FromUnixTimeMilliseconds(epochMs);
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }
}
