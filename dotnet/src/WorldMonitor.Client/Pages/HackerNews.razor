@page "/hacker-news"
@using System.Globalization
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Hacker News</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Top stories on Hacker News</MudText>

<MudButton OnClick="Load" Variant="Variant.Filled" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading" Class="mb-4">
    @(_loading ? "Loading…" : "Refresh")
</MudButton>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="my-2">
        Couldn't load data: @_error
        <div><MudText Typo="Typo.caption">Tip: launch the API host (<code>dotnet run --project dotnet/src/WorldMonitor.Api</code>), not the Client project.</MudText></div>
    </MudAlert>
}
else if (_items is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="_items" Dense="true" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh Style="text-align:right">Score</MudTh>
            <MudTh Style="text-align:right">Comments</MudTh>
            <MudTh>By</MudTh>
            <MudTh>When</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">
                <MudLink Href="@(context.Url ?? $"https://news.ycombinator.com/item?id={context.Id}")" Target="_blank">@context.Title</MudLink>
            </MudTd>
            <MudTd DataLabel="Score" Style="text-align:right">@($"{context.Score.ToString("N0", CultureInfo.InvariantCulture)} pts")</MudTd>
            <MudTd DataLabel="Comments" Style="text-align:right">@context.Comments.ToString("N0", CultureInfo.InvariantCulture)</MudTd>
            <MudTd DataLabel="By">@context.By</MudTd>
            <MudTd DataLabel="When">@Relative(context.At)</MudTd>
        </RowTemplate>
    </MudTable>
    <MudText Typo="Typo.caption" Class="mt-2">@_items.Count stories</MudText>
}

@code {
    private IReadOnlyList<WorldMonitor.Contracts.Tech.HackerNewsStory>? _items;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<WorldMonitor.Contracts.Tech.ListHackerNewsResponse>("api/tech/v1/hacker-news");
            _items = resp?.Items ?? [];
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string Relative(long atMs)
    {
        if (atMs <= 0) return "—";
        var delta = DateTimeOffset.UtcNow - DateTimeOffset.FromUnixTimeMilliseconds(atMs);
        if (delta.Ticks < 0) return "just now";
        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours < 24) return $"{(int)delta.TotalHours}h ago";
        return $"{(int)delta.TotalDays}d ago";
    }
}
